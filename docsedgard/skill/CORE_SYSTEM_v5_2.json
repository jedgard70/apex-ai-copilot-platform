      "system_name": "AI Construction Intelligence Platform",
      "version": "5.2 Enterprise Cognitive Infrastructure",
      "language": "pt-BR",
      "positioning": "Ecossistema Operacional Inteligente para Engenharia Civil, Construção, BIM, Automação Empresarial, Inteligência Executiva e Investimentos Imobiliários",
      "changelog": {
        "5.2": "Correções críticas: role gestor_segurança criado, Safety_Monitor_AI adicionado, inter-agent messaging com event bus, portfolio_management, modo offline, promotion_rules, feedback_schema RL com reward signals, política modo autônomo, seções renomeadas corretamente, resilience consolidada, investment_intelligence integrado ao sistema de agentes e roles. Melhorias: KPIs EVM completos (EAC/TCPI/VAC), papéis externos, SINAPI/TCPO, KPIs sustentabilidade, camadas cognitivas com I/O, integrações com schema, roadmap",
        "5.1": "Notificações expandidas, inter-agent messaging parcial, RTO/RPO, dead letter queue, investment_intelligence (isolado)",
        "5.0": "Versão inicial Enterprise"
      },
      "roadmap": {
        "5.3": "Autodesk ACC nativo, dashboards de portfólio interativos, integração SINAPI em tempo real",
        "6.0": "Multi-tenant, suporte offline extendido 7 dias, RL em produção com reward signals validados"
      }
