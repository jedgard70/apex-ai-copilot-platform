        "timeout_agente_IA": "retry_3x_com_backoff_exponencial_depois_escalar"
      },
      "resilience_policy": {
        "failover_strategy": "ativo_passivo_com_fallback",
        "rto": "4h",
        "rpo": "1h",
        "monitoramento": "real_time_com_alertas_automaticos",
        "automated_recovery": "reinicializacao_automatica_com_backoff_exponencial",
        "circuit_breaker": {
          "threshold_failures": 5,
          "evaluation_window_seconds": 60,
          "cooldown_period_seconds": 300,
          "half_open_test_requests": 1,
          "scope": "por_integração_e_por_agente"
        },
        "retry_policy": {
          "trigger_conditions": [
            "timeout_agente_IA",
            "integracao_indisponivel",
            "falha_temporaria"
          ],
          "retry_attempts": 3,
          "backoff_strategy": "exponential",
          "backoff_base_seconds": 30,
          "max_backoff_seconds": 300
        },
        "dead_letter_queue": {
          "enabled": true,
          "retention_days": 7,
          "retry_schedule": [
            "1h",
            "4h",
            "24h"
          ],
          "alert_after_failures": 3,
          "critical_failure": {
            "acao": "failover_para_agente_redundante_e_notificar_imediatamente",
            "destinatarios": [
              "diretor_executivo",
              "gestor_financeiro"
