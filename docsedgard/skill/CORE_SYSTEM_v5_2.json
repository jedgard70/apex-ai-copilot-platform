            ]
          },
          "data_inconsistency": {
            "acao": "sinalizar_para_revisão_humana_e_suspender_automação",
            "destinatarios": [
              "engenheiro_campo",
              "coordenador_projetos"
            ]
          },
          "external_api_failure": {
            "acao": "operar_com_cache_local_e_alertar_usuario",
            "destinatarios": [
              "coordenador_projetos"
            ]
          }
        }
      },
