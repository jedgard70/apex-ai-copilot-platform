    "kpi_definitions": {
      "prazo": {
        "SPI": {
          "formula": "EV / PV",
          "meta": ">= 0.95",
          "alerta": "< 0.90"
        },
        "desvio_cronograma": {
          "formula": "((data_prevista - data_real) / duracao_total) * 100",
          "meta": "<= 5%",
          "alerta": "> 10%"
        }
      },
      "custo": {
        "CPI": {
          "formula": "EV / AC",
          "meta": ">= 0.95",
          "alerta": "< 0.90"
        },
        "desvio_orçamento": {
          "formula": "((custo_real - orcamento_base) / orcamento_base) * 100",
          "meta": "<= 5%",
          "alerta": "> 10%"
        },
        "EAC": {
          "formula": "BAC / CPI",
          "descrição": "Estimativa de custo total no término com base no desempenho atual"
        },
        "TCPI": {
          "formula": "(BAC - EV) / (BAC - AC)",
          "meta": "<= 1.05",
          "descrição": "Desempenho necessário para entregar dentro do BAC"
        },
        "VAC": {
          "formula": "BAC - EAC",
          "descrição": "Variância no término — positivo = economia, negativo = estouro"
        }
      },
      "qualidade": {
        "taxa_retrabalho": {
          "formula": "(horas_retrabalho / horas_totais) * 100",
          "meta": "<= 3%",
          "alerta": "> 5%"
        },
        "nci_por_área": {
          "formula": "nr_nao_conformidades / 1000m2",
          "meta": "<= 2",
          "alerta": "> 5"
        }
      },
      "segurança": {
        "taxa_frequência_acidentes": {
          "formula": "(nr_acidentes / horas_trabalhadas) * 1000000",
          "meta": "0",
          "alerta": "> 0"
        },
        "dias_sem_acidente": {
          "meta": "365",
          "reset_em": "qualquer_acidente_com_afastamento"
        }
      },
      "bim": {
        "clash_resolution_rate": {
          "formula": "(clashes_resolvidos / clashes_detectados) * 100",
          "meta": ">= 95%",
          "alerta": "< 85%"
        }
      },
      "sustentabilidade": {
        "resíduo_gerado_vs_meta": {
          "formula": "(residuo_gerado_kg / residuo_meta_kg) * 100",
          "meta": "<= 100%",
          "alerta": "> 120%"
        },
        "consumo_água_m3_por_m2": {
          "formula": "consumo_agua_m3 / area_construida_m2",
          "meta": "benchmark_LEED_aplicável"
        },
        "emissão_co2_estimada_ton": {
          "formula": "soma(atividade_i * fator_emissao_i)",
          "meta": "conforme_plano_ambiental_projeto"
        }
      },
      "investimento": {
        "ROI": {
          "formula": "((receita_total - custo_total) / custo_total) * 100",
          "meta": ">= 20%",
          "alerta": "< 10%"
        },
        "TIR": {
          "formula": "taxa_que_torna_VPL_zero",
          "meta": ">= WACC + 5%"
        },
        "VGV": {
          "formula": "preco_unitario_medio * unidades_totais",
          "descrição": "Valor geral de vendas do empreendimento"
        },
        "payback": {
          "formula": "investimento_total / fluxo_caixa_medio_anual",
          "meta": "<= 5 anos"
        }
      }
    },
