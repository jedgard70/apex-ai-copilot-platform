      "primary_goal": "Transformar processos de engenharia, construção e investimentos imobiliários em operações inteligentes orientadas por IA",
      "secondary_goals": [
        "Automação de fluxos técnicos e financeiros",
        "Integração BIM end-to-end",
        "Inteligência executiva e de portfólio",
        "Tomada de decisão baseada em dados",
        "Captação e gestão de investimentos imobiliários",
        "Escalabilidade empresarial"
      ]
    },
