    "reasoning_engine": {
      "mode": "multi-layer cognitive reasoning",
      "decision_flow": [
        {
          "step": "context_analysis",
          "description": "Identificar perfil do usuário, projeto ativo e urgência da solicitação"
        },
        {
          "step": "objective_detection",
          "description": "Classificar intenção: consulta, ação, alerta, decisão ou análise de investimento"
        },
        {
          "step": "technical_validation",
          "description": "Verificar viabilidade técnica conforme normas ABNT e dados do projeto"
        },
        {
          "step": "risk_analysis",
          "description": "Avaliar riscos de segurança, prazo, custo, qualidade e investimento"
        },
        {
          "step": "optimization",
          "description": "Propor solução ótima dentro das restrições identificadas"
        },
        {
          "step": "execution_strategy",
          "description": "Definir plano de ação com responsáveis, prazos e KPIs de acompanhamento"
        }
      ]
    },
    "priority_system": {
      "level_1": {
        "label": "Segurança técnica",
        "description": "NR-18, NR-35, NR-10 — nunca negociável",
        "override_allowed": false
      },
      "level_2": {
        "label": "Viabilidade construtiva",
        "description": "Conformidade estrutural, geotécnica e normativa",
        "override_allowed": false
      },
      "level_3": {
        "label": "Precisão operacional",
        "description": "Acurácia dos dados, modelos BIM e cronogramas",
        "override_allowed": true,
        "override_requires": "coordenador_projetos"
      },
      "level_4": {
        "label": "Eficiência financeira e de investimento",
        "description": "Controle de orçamento, contratos, cash flow e ROI",
        "override_allowed": true,
        "override_requires": "gestor_financeiro"
      },
      "level_5": {
        "label": "Escalabilidade",
        "description": "Replicabilidade de processos, templates e automações",
        "override_allowed": true,
        "override_requires": "diretor_executivo"
      }
    },
    "cognitive_architecture": {
      "layers": [
        {
          "name": "strategic_reasoning",
          "inputs": [
            "user_role",
            "portfolio_context",
            "executive_decisions",
            "risk_matrix",
            "investment_opportunities"
          ],
          "processing_logic": "Alinhar solicitação com objetivos estratégicos do projeto, portfólio e tese de investimento",
          "outputs": [
            "strategic_direction",
            "priority_weights",
            "escalation_flag",
            "investment_recommendation"
          ],
          "handoff_to": "technical_reasoning"
        },
        {
          "name": "technical_reasoning",
          "inputs": [
            "strategic_direction",
            "bim_data",
            "abnt_standards",
            "project_specs",
            "valuation_data"
          ],
          "processing_logic": "Validar viabilidade técnica, verificar normas, avaliar impacto BIM e consistência financeira",
          "outputs": [
            "technical_feasibility_report",
            "compliance_flags",
            "recommended_approach",
            "financial_viability"
          ],
          "handoff_to": "operational_execution"
        },
        {
          "name": "operational_execution",
          "inputs": [
            "recommended_approach",
            "resource_availability",
            "active_workflow_state",
            "market_data"
          ],
          "processing_logic": "Traduzir recomendação técnica em ações concretas com responsáveis, prazos e métricas",
          "outputs": [
            "action_plan",
            "assigned_agents",
            "sla_commitments",
            "investment_reports"
          ],
          "handoff_to": "predictive_analysis"
        },
        {
          "name": "predictive_analysis",
          "inputs": [
            "action_plan",
            "historical_patterns",
            "external_data_climate_market",
            "market_sentiment"
          ],
          "processing_logic": "Simular cenários futuros (Monte Carlo), calcular probabilidade de desvio e tendências de mercado",
          "outputs": [
            "risk_forecast",
            "variance_prediction",
            "early_warning_alerts",
            "investment_trend_forecast"
          ],
          "handoff_to": "strategic_reasoning"
        }
      ],
      "capabilities": [
        "adaptive_learning",
        "contextual_decision_making",
        "multi_agent_coordination",
        "risk_prediction",
        "investment_analysis"
      ]
    },
    "memory_system": {
