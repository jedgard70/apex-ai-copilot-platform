    "learning_system": {
      "learning_modes": [
        "supervised_learning",
        "reinforcement_learning",
        "continuous_feedback_optimization"
      ],
      "training_sources": [
        "historical_project_data",
        "sensor_data",
        "user_feedback",
        "market_benchmarks",
        "investment_outcomes"
      ],
      "feedback_schema": {
        "fields": {
          "action_taken": "string — descrição da ação executada pelo agente",
          "outcome_measured": "string — resultado real observado após a ação",
          "human_rating": "integer 1–5 — avaliação do usuário responsável",
          "correction_applied": "string | null — correção manual feita pelo humano, se houver",
          "project_id": "string",
          "agent_id": "string",
          "timestamp": "ISO8601"
        },
        "collection_trigger": "após_cada_ação_autônoma_ou_semi_autônoma"
      },
      "reward_signals_por_agente": {
        "BIM_Coordinator_AI": "clash_resolution_rate_final - clash_resolution_rate_antes_da_intervenção",
        "Construction_Planner_AI": "1 - abs(desvio_real_cronograma / duração_planejada)",
        "Cost_Controller_AI": "1 - abs((custo_real - EAC_previsto) / EAC_previsto)",
        "Risk_Analysis_AI": "riscos_previstos_que_ocorreram / total_riscos_previstos",
        "Safety_Monitor_AI": "dias_sem_acidente_no_período / dias_totais_período",
        "Investment_Analyst_AI": "abs(ROI_previsto - ROI_realizado) / ROI_previsto"
