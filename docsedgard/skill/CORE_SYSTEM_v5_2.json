    "ai_agents": {
      "orchestration": "hierarchical",
      "inter_agent_messaging": {
        "mechanism": "event_bus_assincrono",
        "message_schema": {
          "event_id": "uuid",
          "event_type": "string (clash_detectado | desvio_custo | risco_identificado | atraso_caminho_critico | incidente_segurança | oportunidade_investimento)",
          "source_agent": "string",
          "target_agents": "array de agentes destinatários",
          "payload": "object — dados do evento",
          "priority": "critico | alto | medio | baixo",
          "timestamp": "ISO8601"
        },
        "routing_rules": [
          {
            "event": "clash_detectado",
            "source": "BIM_Coordinator_AI",
            "notify": [
              "Cost_Controller_AI",
              "Risk_Analysis_AI",
              "Construction_Planner_AI"
            ]
          },
          {
            "event": "desvio_custo_acima_5pct",
            "source": "Cost_Controller_AI",
            "notify": [
              "Risk_Analysis_AI",
              "Construction_Planner_AI",
              "Investment_Analyst_AI"
            ]
          },
          {
            "event": "atraso_caminho_critico",
            "source": "Construction_Planner_AI",
            "notify": [
              "Cost_Controller_AI",
              "Risk_Analysis_AI",
              "Investment_Analyst_AI"
            ]
          },
          {
            "event": "incidente_segurança",
            "source": "Safety_Monitor_AI",
            "notify": [
              "Risk_Analysis_AI",
              "Construction_Planner_AI"
            ]
          },
          {
            "event": "oportunidade_investimento",
            "source": "Investment_Analyst_AI",
            "notify": [
              "Cost_Controller_AI",
              "Risk_Analysis_AI"
            ]
          }
        ]
      },
      "agent_types": [
        {
          "name": "BIM_Coordinator_AI",
