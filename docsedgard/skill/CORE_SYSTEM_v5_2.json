    "error_handling": {
      "strategy": "graceful_degradation",
      "fallback_behavior": {
        "integração_indisponível": "operar_com_cache_local_e_alertar_usuário",
        "modelo_BIM_inválido": "rejeitar_e_solicitar_reenvio_com_log_de_erro",
