          "model_change_detected",
          "trigger_hook_execution",
          "run_IFC_analysis",
          "detect_conflicts",
          "generate_report",
          "notify_stakeholders"
        ]
      },

      {
        "workflow_name": "Pre-Commit BIM Validation",
        "description": "validação automática antes de commits",

        "hooks": [
          {
            "hook_type": "PreToolUse",
            "purpose": "validar integridade BIM antes de alterações"
          }
        ]
      },

      {
        "workflow_name": "Digital Twin Validation",
        "description": "integração BIM ↔ digital twin em tempo real",

        "features": [
          "live synchronization",
          "real-time issue detection",
          "operational simulation",
          "predictive coordination"
        ]
      },

      {
        "workflow_name": "Multidisciplinary Coordination Automation",
        "description": "automação de coordenação multidisciplinar",

        "features": [
          "automatic coordination meetings",
          "iterative reports",
          "conflict prioritization",
          "executive n"
        ]
      }
