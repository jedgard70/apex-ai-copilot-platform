    "ai_agents": {
      "orchestration": "hierarchical",
      "agent_types": [
        {
          "name": "BIM_Coordinator_AI",
          "role": "Coordenação e validação BIM",
          "triggers": ["upload_de_modelo", "solicitacao_clash_detection", "revisao_de_compatibilidade"],
          "inputs": ["arquivo_IFC_RVT_DWG", "parametros_de_tolerancia", "disciplinas_envolvidas"],
          "outputs": ["relatorio_de_interferencias", "modelo_federado_validado", "lista_de_pendencias"],
          "n_to": "coordenador_projetos"
        },
        {
          "name": "Construction_Planner_AI",
          "role": "Planejamento e cronogramas",
          "triggers": ["criacao_de_projeto", "replanejamento", "atraso_detectado"],
          "inputs": ["wbs", "recursos_disponiveis", "restricoes_de_prazo", "historico_de_projetos"],
          "outputs": ["cronograma_ms_project", "analise_caminho_critico", "simulacao_monte_carlo"],
          "n_to": "coordenador_projetos"
        },
        {
          "name": "Cost_Controller_AI",
          "role": "Controle financeiro e orçamento",
          "triggers": ["entrada_de_nota_fiscal", "desvio_orcamentario_acima_5%", "fechamento_mensal"],
          "inputs": ["orcamento_base", "medicoes", "contratos", "aditivos"],
          "outputs": ["relatorio_vpe", "curva_s_atualizada", "forecast_conclusao", "alertas_desvio"],
          "n_to": "gestor_financeiro"
        },
        {
          "name": "Risk_Analysis_AI",
          "role": "Análise preditiva de riscos",
          "triggers": ["evento_clima_extremo", "desvio_cronograma_acima_10%", "incidente_seguranca", "novo_projeto"],
          "inputs": ["dados_projeto_ativo", "historico_riscos", "dados_externos_clima_mercado"],
          "outputs": ["matriz_riscos_atualizada", "plano_resposta", "probabilidade_atraso", "impacto_financeiro"],
          "n_to": "coordenador_projetos"
        }
      ],
      "inter_agent_messaging": {
        "protocol": "custom_json_rpc",
        "message_structure": {
          "sender": "agent_name",
          "receiver": "agent_name",
          "timestamp": "ISO8601",
          "message_type": ["request", "response", "notification"],
          "payload": {
            "data": "context_specific",
            "parameters": "context_specific",
            "metadata": {
              "priority": "high/medium/low",
              "retries": 0,
              "correlation_id": "uuid4"
            }
          }
        },
        "security": {
          "authentication": "token_based",
          "encryption": "AES256"
        },
        "example_clash_notification": {
          "clash_id": "12345",
          "severity": "hard",
          "location": "pilar A3",
          "involved_elements": ["pilar A3", "viga B2"],
          "timestamp": "2024-06-01T14:30:00Z",
          "sender": "BIM_Coordinator_AI",
          "receiver": "Cost_Controller_AI"
        }
      }
    },

