        },
        {
          "trigger": "decisao_que_violam_normas_sustentabilidade",
          "acao": "bloquear_decisao_e_notificar",
          "destinatarios": ["gestor_sustentabilidade", "diretor_executivo"],
          "prazo": "1h"
        }
      ],
      "human_in_the_loop_obrigatorio": [
        "aprovacao_aditivos_contratuais",
        "decisoes_de_paralisacao_de_obra",
        "contratacao_emergencial",
        "divulgacao_de_incidentes_externos",
        "decisoes_estrategicas_com_impacto_portfolio",
