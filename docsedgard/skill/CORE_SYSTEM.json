    "domain_standards": {
      "seguranca_trabalho": ["NR-18", "NR-35", "NR-10", "NR-12"],
      "normas_tecnicas_abnt": [
        "NBR_6118 (concreto estrutural)",
        "NBR_6120 (cargas para cálculo)",
        "NBR_14645 (levantamentos topográficos)",
        "NBR_15575 (desempenho edificações)",
        "NBR_16280 (reformas)"
      ],
      "bim_mandatos": ["BIM_Level_2", "ISO_19650"],
      "sustentabilidade": ["LEED", "AQUA_HQE", "PROCEL_Edifica"]
    },

    "kpi_definitions": {
      "prazo": {
        "SPI": { "formula": "EV / PV", "meta": ">= 0.95", "alerta": "< 0.90" },
        "desvio_cronograma": { "formula": "((data_prevista - data_real) / duracao_total) * 100", "meta": "<= 5%", "alerta": "> 10%" }
      },
      "custo": {
        "CPI": { "formula": "EV / AC", "meta": ">= 0.95", "alerta": "< 0.90" },
        "desvio_orcamento": { "formula": "((custo_real - orcamento_base) / orcamento_base) * 100", "meta": "<= 5%", "alerta": "> 10%" }
      },
      "qualidade": {
        "taxa_retrabalho": { "formula": "(horas_retrabalho / horas_totais) * 100", "meta": "<= 3%", "alerta": "> 5%" },
        "nci_por_area": { "formula": "nº_nao_conformidades / 1000m²", "meta": "<= 2", "alerta": "> 5" }
      },
      "seguranca": {
        "taxa_frequencia_acidentes": { "formula": "(nº_acidentes / horas_trabalhadas) * 1.000.000", "meta": "0", "alerta": "> 0" },
        "dias_sem_acidente": { "meta": "365", "reset_em": "qualquer_acidente_com_afastamento" }
      },
      "bim": {
        "clash_resolution_rate": { "formula": "(clashes_resolvidos / clashes_detectados) * 100", "meta": ">= 95%", "alerta": "< 85%" }
      }
    },

    "n_rules": {
      "auto_escalate_conditions": [
        {
          "trigger": "acidente_com_afastamento",
          "acao": "notificar_imediato",
          "destinatarios": ["diretor_executivo", "gestor_seguranca", "juridico"],
          "prazo": "imediato"
        },
        {
          "trigger": "desvio_orcamento_acima_15%",
          "acao": "bloquear_aprovacoes_e_notificar",
          "destinatarios": ["gestor_financeiro", "diretor_executivo"],
          "prazo": "2h"
        },
        {
          "trigger": "clash_critico_estrutural_detectado",
          "acao": "pausar_etapa_e_notificar",
          "destinatarios": ["engenheiro_responsavel", "coordenador_projetos"],
          "prazo": "1h"
        },
        {
          "trigger": "atraso_caminho_critico_acima_10dias",
          "acao": "replanejamento_emergencial",
          "destinatarios": ["coordenador_projetos", "diretor_executivo"],
          "prazo": "24h"
        },
        {
          "trigger": "incidente_seguranca",
          "acao": "investigacao_imediata_e_notificacao",
          "destinatarios": ["gestor_seguranca", "diretor_executivo", "coordenador_projetos"],
          "prazo": "imediato"
        },
        {
          "trigger": "decisao_com_risco_critico_identificado",
          "acao": "bloquear_decisao_e_notificar",
          "destinatarios": ["coordenador_projetos", "diretor_executivo"],
          "prazo": "imediato"
        },
        {
          "trigger": "decisao_que_violam_normas_de_seguranca",
          "acao": "bloquear_decisao_e_notificar",
          "destinatarios": ["gestor_seguranca", "diretor_executivo"],
          "prazo": "imediato"
        },
        {
          "trigger": "decisao_que_violam_normas_tecnicas_abnt",
          "acao": "bloquear_decisao_e_notificar",
          "destinatarios": ["engenheiro_responsavel", "coordenador_projetos"],
          "prazo": "1h"
        },
        {
          "trigger": "decisao_que_violam_bim_mandatos",
          "acao": "bloquear_decisao_e_notificar",
