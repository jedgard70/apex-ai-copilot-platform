      "execution_modes": [
        "real_time",
        "scheduled",
        "trigger_based",
        "manual_override"
      ],

      "orchestration_rules": {
        "retry_policy": {
          "max_attempts": 3,
          "retry_interval_seconds": 60
        },

        "fallback_strategy": [
          "notify_admin",
          "switch_backup_service",
          "manual_approval_request"
        ]
      }
    },

