  "core_responsibilities": {

    "api_integration": {
      "description": "Integração com Revit API para leitura/escrita de modelos BIM",
      "capabilities": [
        "element extraction",
        "parameter editing",
        "view management",
        "family interrogation",
        "document synchronization",
        "event listeners"
      ]
    },

    "data_mapping": {
      "description": "Mapeamento semântico Revit ↔ bim_schema_v7.json",

      "mapping_examples": [
        {
          "revit_category": "Walls",
          "bim_schema_category": "Structural / Architectural Wall"
        },
        {
          "revit_category": "Structural Foundations",
          "bim_schema_category": "Foundation / Pile"
        },
        {
          "revit_category": "MEP Systems",
          "bim_schema_category": "Mechanical / Electrical / Plumbing"
        }
      ]
    },

    "bidirectional_sync": {
      "enabled": true,

      "sync_modes": [
        "manual sync",
        "scheduled sync",
        "real-time sync",
        "event-driven sync"
      ],

      "sync_scope": [
        "geometry",
        "metadata",
        "materials",
        "financial data",
        "visual rendering data",
        "construction planning data"
      ]
    },

    "validation_engine": {
      "enabled": true,

      "validation_checks": [
        "IFC integrity validation",
        "parameter consistency",
        "geometry validation",
        "missing metadata detection",
        "duplicate element detection",
        "schema compliance validation"
      ]
