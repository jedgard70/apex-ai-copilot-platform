{
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/copilot/operator-preview", "destination": "/api/copilot/operator?action=preview" },
    { "source": "/api/copilot/operator-status", "destination": "/api/copilot/operator?action=status" },
    { "source": "/api/copilot/operator-execute", "destination": "/api/copilot/operator?action=execute" },
    { "source": "/api/copilot/execution/commands", "destination": "/api/copilot/execution?action=commands" },
    { "source": "/api/copilot/execution/run", "destination": "/api/copilot/execution?action=run" },
    { "source": "/api/mcp/:path*", "destination": "/api/copilot/mcp.mjs" },
    { "source": "/api/mcp", "destination": "/api/copilot/mcp.mjs" },
    { "source": "/api/prompts/:path*", "destination": "/api/prompts/index.mjs" },
    { "source": "/api/reports/:path*", "destination": "/api/reports/index.mjs" },
    { "source": "/api/deploy-hook/:path*", "destination": "/api/deploy-hook/:path*" },
    { "source": "/v1/:path*", "destination": "/api/v1/:path*" },
    { "source": "/premium", "destination": "/premium.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/upgrade-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/deploy-nightly",
      "schedule": "0 6 * * *"
    }
  ]
}
