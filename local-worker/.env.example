# Apex Local Worker — copy this to .env and fill in values
# NEVER commit the real .env file

# Secret token used to authenticate requests from the Apex backend.
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_WORKER_TOKEN=replace-with-a-strong-random-secret

# Port the worker listens on (default: 8787)
LOCAL_WORKER_PORT=8787

# Absolute path to your local Apex project clone
APEX_PROJECT_PATH=D:\AI-constr\apex-ai-copilot-platform
