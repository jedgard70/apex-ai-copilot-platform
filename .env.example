GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-expose
