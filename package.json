  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node server.mjs",
    "dev:ui": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server.mjs",
    "validate:cp15x-h43b": "node scripts/validate-cp15x-h43b.mjs",
    "validate:cp15x-h44": "node scripts/validate-cp15x-h44.mjs",
    "validate:cp15x-h5": "node scripts/validate-cp15x-h5.mjs",
    "validate:cp15x-h51a": "node scripts/validate-cp15x-h51a.mjs",
    "validate:supabase-sql": "node scripts/validate-supabase-sql.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.108.1",
    "@vitejs/plugin-react": "^4.3.4",
    "docx": "^9.7.1",
    "lucide-react": "^0.511.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "web-ifc": "^0.0.77",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  }
