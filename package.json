{
  "name": "apex-ai-copilot-platform",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "node scripts/dev-live.mjs",
    "dev:full": "node scripts/dev-full.mjs",
    "worker": "node local-worker/server.mjs",
    "electron:dev": "node scripts/start-electron-dev.mjs",
    "electron:build": "npm run build && node node_modules/electron-builder/cli.js",
    "daemon": "node local-worker/server.mjs",
    "engine": "node server/apex-engine-proxy.mjs",
    "dev:ui": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "start": "node server.mjs",
    "test:e2e": "npm run build && node node_modules/@playwright/test/cli.js test",
    "test:e2e:headed": "npm run build && node node_modules/@playwright/test/cli.js test --headed",
    "validate:cp15x-h43b": "node scripts/validate-cp15x-h43b.mjs",
    "validate:cp15x-h44": "node scripts/validate-cp15x-h44.mjs",
    "validate:cp15x-h5": "node scripts/validate-cp15x-h5.mjs",
    "validate:cp15x-h51a": "node scripts/validate-cp15x-h51a.mjs",
    "validate:supabase-sql": "node scripts/validate-supabase-sql.mjs",
    "validate:owner-workspace-live": "node scripts/validate-owner-workspace-live.mjs",
    "validate:directcut-pipeline": "node scripts/validate-directcut-pipeline.mjs",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "train": "node scripts/train-apex-ai.mjs",
    "train:dry": "node scripts/train-apex-ai.mjs --dry-run",
    "setup:runtime": "node scripts/setup-own-runtime.mjs",
    "setup:runtime:check": "node scripts/setup-own-runtime.mjs --check",
    "setup:soberania": "node scripts/setup-soberania.mjs"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.19.0",
    "@auth0/nextjs-auth0": "^4.22.0",
    "@genkit-ai/googleai": "^1.28.0",
    "@google/genai": "^2.9.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/node": "^10.59.0",
    "@sentry/react": "^10.59.0",
    "@supabase/server": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/connect": "^0.2.5",
    "@vercel/speed-insights": "^1.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.11.2",
    "ai": "6.0.208",
    "cors": "^2.8.6",
    "csstype": "^3.1.3",
    "docx": "^9.7.1",
    "dompurify": "^3.1.6",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "fast-xml-parser": "5.9.3",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "genkit": "^1.37.0",
    "googleapis": "^173.0.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "mcp-handler": "^1.1.0",
    "mdn-data": "^2.28.1",
    "node-llama-cpp": "^3.19.0",
    "node-pty": "^1.1.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pptxgenjs": "^4.0.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.4.0",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "web-ifc": "^0.0.77",
    "whatsapp-web.js": "^1.34.7",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.17.1",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "compression": "normal",
    "appId": "com.apexglobalai.copilot",
    "productName": "Apex AI Copilot",
    "directories": {
      "output": "dist_electron"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "asarUnpack": [
      "runtime/**/*"
    ],
    "files": [
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/__tests__/**",
      "dist_electron/**/*",
      "dist/**/*",
      "api/**/*",
      "server/**/*",
      "local-worker/**/*",
      "runtime/**/*",
      "server.mjs",
      "electron-main.cjs",
      "package.json",
      ".env.local"
    ],
    "win": {
      "target": ["nsis", "dir"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Apex AI Copilot"
    },
    "publish": {
      "provider": "github",
      "owner": "Apex-Global-LLC",
      "repo": "apex-ai-copilot-platform",
      "releaseType": "release"
    }
  },
  "description": "Clean rebuild of the Apex AI Copilot platform.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jedgard70/apex-ai-copilot-platform.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jedgard70/apex-ai-copilot-platform/issues"
  },
  "homepage": "https://github.com/jedgard70/apex-ai-copilot-platform#readme"
}
